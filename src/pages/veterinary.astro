---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/shared/SiteHeader.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
import { SectionHeader } from '../components/shared/SectionHeader.tsx';
import { HorizontalBarChart } from '../components/charts/HorizontalBarChart';
import { WilayaMap } from '../components/charts/WilayaMap';
import { DataExplorer } from '../components/explorer/DataExplorer';
import { t, getTranslations } from '../lib/i18n';
import ChapterNav from '../components/shared/ChapterNav.astro';
import InsightCallout from '../components/shared/InsightCallout.astro';
import { loadVetAuthorizations, loadVetDistributors, loadVetMedicineImporters } from '../lib/data';
import { WILAYA_BY_CODE, wilayaCodeFromName } from '../data/wilaya-names';
import type { Lang } from '../lib/types';

const lang: Lang = 'ar';
const auths        = loadVetAuthorizations();
const distributors = loadVetDistributors();
const importers    = loadVetMedicineImporters();

function normalizeWilaya(raw: string): string {
  return raw.trim()
    .replace(/'/g, "'")
    .replace(/\s+/g, ' ')
    .replace(/\b([A-Z]{2,})\b/g, (m) => m.charAt(0) + m.slice(1).toLowerCase())
    .replace('Bba', 'Bordj Bou Arréridj')
    .replace("M'sila", "M'Sila")
    .replace('Boumerdes', 'Boumerdès')
    .replace('Ain Defla', 'Aïn Defla')
    .replace('Ain Temouchent', 'Aïn Témouchent');
}

const wilayaCounts: Record<string, number> = {};
for (const r of distributors) {
  if (r.wilaya) {
    const w = normalizeWilaya(r.wilaya);
    wilayaCounts[w] = (wilayaCounts[w] ?? 0) + 1;
  }
}
const wilayaChartData = Object.entries(wilayaCounts)
  .map(([frName, count]) => {
    const code = wilayaCodeFromName(frName);
    const label = code ? (WILAYA_BY_CODE[code]?.[lang] ?? frName) : frName;
    return { label, count };
  })
  .sort((a, b) => b.count - a.count)
  .slice(0, 20);

// Wilayas with zero vet distributors
const coveredWilayas = new Set(Object.keys(wilayaCounts).map(w => w.toLowerCase()));
const absentWilayas = Object.values(WILAYA_BY_CODE)
  .filter(w => !Array.from(coveredWilayas).some(c => c.includes(w.fr.toLowerCase()) || c.includes(w.en.toLowerCase())))
  .map(w => w.ar)
  .sort();

const typeCounts: Record<string, number> = {};
for (const r of auths) {
  const pt = r.productType || 'Autre';
  typeCounts[pt] = (typeCounts[pt] ?? 0) + 1;
}
const typeChartData = Object.entries(typeCounts)
  .map(([label, count]) => ({ label, count }))
  .sort((a, b) => b.count - a.count);

const explorerRows = distributors.map(r => ({
  company: r.companyNameAr || r.company,
  wilaya:  r.wilaya,
  number:  r.number,
  address: r.address,
}));

const explorerColumns = [
  { key: 'company', label: 'الشركة' },
  { key: 'wilaya',  label: 'الولاية', mono: true },
  { key: 'number',  label: 'الرقم',   mono: true },
  { key: 'address', label: 'العنوان' },
];

const tr = getTranslations(lang);
const explorerI18n = {
  search_placeholder: tr.explorer.search_placeholder,
  filter_country:     tr.explorer.filter_country,
  filter_category:    tr.explorer.filter_category,
  filter_all:         tr.explorer.filter_all,
  no_results:         tr.explorer.no_results,
  showing:            tr.explorer.showing,
  of:                 tr.explorer.of,
  records:            tr.explorer.records,
  prev:               tr.explorer.prev,
  next:               tr.explorer.next,
};
---

<BaseLayout title={t(lang, 'chapters.ch4_title')} lang={lang}>
  <SiteHeader lang={lang} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-14 flex-1">

    <InsightCallout
      stat="19"
      label="ولاية بدون موزّع بيطري"
      context="من أصل 58 ولاية جزائرية، 19 ولاية لا يوجد فيها أي موزع مرخص للأدوية البيطرية. الغرب والجنوب الكبير الأكثر تضرراً."
      accent={true}
    />

    <SectionHeader
      chapterNum={t(lang, 'chapters.ch4_num')}
      title={t(lang, 'chapters.ch4_title')}
      lead={t(lang, 'chapters.ch4_lead')}
      client:visible
    />

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{auths.length.toLocaleString('ar-DZ')}</div>
        <div class="text-xs text-muted font-body mt-1">تراخيص</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{distributors.length.toLocaleString('ar-DZ')}</div>
        <div class="text-xs text-muted font-body mt-1">موزع</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{importers.length.toLocaleString('ar-DZ')}</div>
        <div class="text-xs text-muted font-body mt-1">مستورد</div>
      </div>
    </div>

    <section class="mb-10">
      <WilayaMap
        counts={wilayaCounts}
        title="توزيع الموزعين البيطريين حسب الولاية — 58 ولاية جزائرية"
        lang="ar"
        client:visible
      />
    </section>

    <div class="grid md:grid-cols-2 gap-8 mb-14">
      <HorizontalBarChart
        data={wilayaChartData}
        maxBars={20}
        colorByLabel={true}
        title="توزيع الموزعين حسب الولاية"
        isRtl={true}
        client:visible
      />
      <HorizontalBarChart
        data={typeChartData}
        colorByLabel={false}
        title="أنواع المنتجات المرخصة"
        isRtl={true}
        client:visible
      />
    </div>

    {/* Absent wilayas */}
    <div class="mb-10 max-w-2xl p-5 rounded-lg" style="background: rgba(252,92,101,0.04); border: 1px solid rgba(252,92,101,0.18);">
      <p class="text-xs font-mono font-bold mb-2" style="color: #e03131;">الولايات الغائبة تماماً ({absentWilayas.length} ولاية)</p>
      <p class="text-sm font-body leading-relaxed text-muted mb-3">
        هذه الولايات لا يوجد فيها أي موزع بيطري مرخص — معظمها في الجنوب رغم أنها من أهم مناطق تربية الإبل والغنم في الجزائر.
      </p>
      <div class="flex flex-wrap gap-2">
        {absentWilayas.map((w: string) => (
          <span class="text-xs font-mono px-2 py-0.5 rounded" style="background: rgba(252,92,101,0.1); color: #c92a2a;">{w}</span>
        ))}
      </div>
    </div>

    <h2 class="font-display font-bold text-display-sm text-ink mb-6">
      {t(lang, 'chapters.ch4_title')}
    </h2>
    <DataExplorer
      rows={explorerRows}
      columns={explorerColumns}
      searchKeys={['company', 'wilaya', 'address']}
      filterKey="wilaya"
      i18n={explorerI18n}
      client:visible
    />

    <ChapterNav
      lang={lang}
      prev={{ href: '/players', num: '03', title: t(lang, 'chapters.ch3_title') }}
    />

  </main>

  <SiteFooter lang={lang} />
</BaseLayout>

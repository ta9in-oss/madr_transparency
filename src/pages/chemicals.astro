---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/shared/SiteHeader.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
import { SectionHeader } from '../components/shared/SectionHeader.tsx';
import { HorizontalBarChart } from '../components/charts/HorizontalBarChart';
import { WorldMap } from '../components/charts/WorldMap';
import { DataExplorer } from '../components/explorer/DataExplorer';
import { t, getTranslations } from '../lib/i18n';
import ChapterNav from '../components/shared/ChapterNav.astro';
import InsightCallout from '../components/shared/InsightCallout.astro';
import { loadAgrochemicals } from '../lib/data';
import { countryToIso, countryName, COUNTRY_INFO } from '../lib/countries';
import type { Lang } from '../lib/types';
import insightsJson from '../../data/insights.json';
const insights = insightsJson as any;

const lang: Lang = 'ar';

const narrative = (insights.chemicals?.narrative as {fr: string; ar: string; en: string} | undefined)?.[lang];

const records = loadAgrochemicals();
// category is already normalized by loadAgrochemicals() via normalizeChemicalCategory()

const catCounts: Record<string, number> = {};
for (const r of records) {
  catCounts[r.category] = (catCounts[r.category] ?? 0) + 1;
}
const categoryChartData = Object.entries(catCounts)
  .map(([label, count]) => ({ label, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 20);

// ISO-normalized country grouping
const isoCounts: Record<string, number> = {};
for (const r of records) {
  const iso = countryToIso(r.countryOfOrigin || 'INCONNU');
  isoCounts[iso] = (isoCounts[iso] ?? 0) + 1;
}
const countryChartData = Object.entries(isoCounts)
  .filter(([iso]) => iso !== 'XX')
  .map(([iso, count]) => ({ label: countryName(iso, lang), count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 12);

// World bubble map data
const worldMapData = Object.entries(isoCounts)
  .filter(([iso]) => COUNTRY_INFO[iso])
  .map(([iso, count]) => ({ iso, count, label: countryName(iso, lang) }))
  .sort((a, b) => b.count - a.count);

const explorerRows = records.map(r => ({
  company:   r.companyNameAr || r.company,
  product:   r.productName,
  substance: r.activeSubstance,
  category:  r.category,
  origin:    countryName(r.countryOfOrigin, lang),
}));

const explorerColumns = [
  { key: 'company',   label: 'الشركة' },
  { key: 'product',   label: 'المنتج',         mono: true },
  { key: 'substance', label: 'المادة الفعالة', mono: true },
  { key: 'category',  label: 'الفئة',          mono: true },
  { key: 'origin',    label: 'المنشأ',         mono: true },
];

const tr = getTranslations(lang);
const explorerI18n = {
  search_placeholder: tr.explorer.search_placeholder,
  filter_country:     tr.explorer.filter_country,
  filter_category:    tr.explorer.filter_category,
  filter_all:         tr.explorer.filter_all,
  no_results:         tr.explorer.no_results,
  showing:            tr.explorer.showing,
  of:                 tr.explorer.of,
  records:            tr.explorer.records,
  prev:               tr.explorer.prev,
  next:               tr.explorer.next,
};
---

<BaseLayout title={t(lang, 'chapters.ch2_title')} lang={lang}>
  <SiteHeader lang={lang} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-14 flex-1">

    <InsightCallout
      stat={insights.chemicals.total.toLocaleString()}
      label="مادة كيميائية مرخصة للدخول"
      context="إسبانيا وحدها مصدر أكثر من 900 منتج. والصين في المرتبة الثالثة. كل هذا يُرش على الأراضي الزراعية الجزائرية."
      accent={true}
    />

    <SectionHeader
      chapterNum={t(lang, 'chapters.ch2_num')}
      title={t(lang, 'chapters.ch2_title')}
      lead={t(lang, 'chapters.ch2_lead')}
      client:visible
    />

    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{insights.chemicals.spain_count.toLocaleString()}</div>
        <div class="text-xs text-muted font-body mt-1">منتج إسباني، المرتبة الأولى</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{insights.chemicals.italy_count.toLocaleString()}</div>
        <div class="text-xs text-muted font-body mt-1">منتج إيطالي، المرتبة الثانية</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{insights.chemicals.china_count.toLocaleString()}</div>
        <div class="text-xs text-muted font-body mt-1">منتج صيني، المرتبة الثالثة ومتزايد</div>
      </div>
    </div>

    <section class="mb-10">
      <WorldMap
        data={worldMapData}
        title="خريطة مصادر الاستيراد: من أين تأتي المواد الكيميائية الزراعية؟"
        client:visible
      />
    </section>

    <div class="grid md:grid-cols-2 gap-8 mb-14">
      <HorizontalBarChart
        data={categoryChartData}
        colorByLabel={true}
        title={tr.explorer.filter_category}
        isRtl={true}
        client:visible
      />
      <HorizontalBarChart
        data={countryChartData}
        colorByLabel={false}
        maxBars={12}
        title={tr.explorer.filter_country}
        isRtl={true}
        client:visible
      />
    </div>

    <h2 class="font-display font-bold text-display-sm text-ink mb-6">
      {t(lang, 'chapters.ch2_title')}
    </h2>
    <DataExplorer
      rows={explorerRows}
      columns={explorerColumns}
      searchKeys={['company', 'product', 'substance']}
      filterKey="category"
      i18n={explorerI18n}
      client:visible
    />

    {/* Data quality note */}
    <div class="mb-10 max-w-2xl p-5 rounded-lg" style="background: rgba(45,106,79,0.04); border: 1px solid rgba(45,106,79,0.2);">
      <p class="text-xs font-mono font-bold mb-2 text-forest">⚠ جودة البيانات الخام</p>
      <p class="text-sm font-body leading-relaxed text-muted">
        عمود "الفئة" الأصلي يحتوي على <strong class="text-ink">261 قيمة فريدة</strong> لـ14 نوع أساسي فقط.
        "BIOSTIMULANT" و"Biostimulant" و"bio stimulant" و"Bio Stimulant" و"BIOSTUMILANT" (خطأ إملائي)
        كلها نفس الفئة. قمنا بالتوحيد إلى 14 مجموعة قابلة للمقارنة.
      </p>
    </div>

    {narrative && (
      <div class="mb-10 max-w-2xl p-5 rounded-lg bg-surface border border-line" style="border-left: 3px solid #2d6a4f;">
        <p class="text-xs font-mono font-bold text-forest mb-2">
          {lang === 'ar' ? '✦ تحليل ذكاء اصطناعي' : lang === 'fr' ? '✦ Analyse par IA' : '✦ AI Analysis'}
        </p>
        <p class="text-sm font-body leading-relaxed text-ink">{narrative}</p>
      </div>
    )}

    <ChapterNav
      lang={lang}
      prev={{ href: '/dependency', num: '01', title: t(lang, 'chapters.ch1_title') }}
      next={{ href: '/players', num: '03', title: t(lang, 'chapters.ch3_title') }}
    />

  </main>

  <SiteFooter lang={lang} />
</BaseLayout>

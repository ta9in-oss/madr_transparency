---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/shared/SiteHeader.astro';
import SiteFooter from '../../components/shared/SiteFooter.astro';
import { SectionHeader } from '../../components/shared/SectionHeader';
import { HorizontalBarChart } from '../../components/charts/HorizontalBarChart';
import { WorldMap } from '../../components/charts/WorldMap';
import { DataExplorer } from '../../components/explorer/DataExplorer';
import { t, getTranslations } from '../../lib/i18n';
import { countryName } from '../../lib/countries';
import { PLANT_CATEGORY_LABELS, SEED_MATERIAL_LABELS } from '../../lib/categoryColors';
import ChapterNav from '../../components/shared/ChapterNav.astro';
import InsightCallout from '../../components/shared/InsightCallout.astro';
import {
  loadPlantProducts,
  loadSeedlings,
  loadSeeds,
  loadPotatoSeeds,
} from '../../lib/data';
import type { Lang } from '../../lib/types';
import insightsJson from '../../../data/insights.json';
const insights = insightsJson as any;

const lang: Lang = 'fr';

const narrative = (insights.dependency?.narrative as {fr: string; ar: string; en: string} | undefined)?.[lang];

const plantProducts = loadPlantProducts();
const seedlings     = loadSeedlings();
const seeds         = loadSeeds();
const potatoSeeds   = loadPotatoSeeds();

const totalCount = plantProducts.length + seedlings.length + seeds.length + potatoSeeds.length;

const allRecords = [...plantProducts, ...seedlings, ...seeds, ...potatoSeeds];

const isoCounts: Record<string, number> = {};
for (const r of allRecords) {
  const iso = r.countryOfOrigin || 'XX';
  if (iso !== 'XX') {
    isoCounts[iso] = (isoCounts[iso] ?? 0) + 1;
  }
}

const countryData: { label: string; count: number }[] = Object.entries(isoCounts)
  .filter(([iso]) => iso !== 'XX')
  .map(([iso, count]) => ({ label: countryName(iso, lang), count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 15);

const seedMatData = Object.entries(
  (insights.dependency.seed_material_breakdown as Record<string, number>) ?? {}
)
  .filter(([, count]) => count > 0)
  .map(([frKey, count]) => ({
    label: SEED_MATERIAL_LABELS[frKey]?.[lang] ?? frKey,
    count,
  }))
  .sort((a, b) => b.count - a.count);

// World map: combine plant + seed origins from insights
const worldMapData = [
  ...(insights.dependency.top_plant_countries as {key: string; count: number}[]),
  ...(insights.dependency.top_seed_countries as {key: string; count: number}[]),
].reduce((acc, { key: iso, count }) => {
  acc[iso] = (acc[iso] ?? 0) + count;
  return acc;
}, {} as Record<string, number>);

const worldMapChartData = Object.entries(worldMapData)
  .filter(([iso]) => iso !== 'XX')
  .map(([iso, count]) => ({ iso, count, label: countryName(iso, lang) }))
  .sort((a, b) => b.count - a.count);

// Plant category breakdown
const plantCatData = Object.entries(
  (insights.dependency.plant_category_breakdown as Record<string, number>) ?? {}
)
  .filter(([, count]) => count > 0)
  .map(([frKey, count]) => ({
    label: PLANT_CATEGORY_LABELS[frKey]?.[lang] ?? frKey,
    count,
  }))
  .sort((a, b) => b.count - a.count);

const combinedExplorerRows = [
  ...plantProducts.map((r) => ({
    company:  r.companyNameAr || r.company,
    variety:  r.variety || r.knownName || '—',
    sector:   'Produits végétaux',
    category: PLANT_CATEGORY_LABELS[r.category]?.[lang] ?? r.category,
    origin:   countryName(r.countryOfOrigin, lang),
  })),
  ...seeds.map((r) => ({
    company:  (r as any).companyNameAr || r.company,
    variety:  r.variety || '—',
    sector:   'Semences',
    category: SEED_MATERIAL_LABELS[(r as any).materialType ?? '']?.[lang] ?? '—',
    origin:   countryName(r.countryOfOrigin, lang),
  })),
  ...seedlings.map((r) => ({
    company:  (r as any).companyNameAr || r.company,
    variety:  r.variety || '—',
    sector:   'Plants',
    category: SEED_MATERIAL_LABELS[(r as any).materialType ?? '']?.[lang] ?? '—',
    origin:   countryName(r.countryOfOrigin, lang),
  })),
  ...potatoSeeds.map((r) => ({
    company:  (r as any).companyNameAr || r.company,
    variety:  r.variety || '—',
    sector:   'Pomme de terre',
    category: SEED_MATERIAL_LABELS[(r as any).materialType ?? '']?.[lang] ?? '—',
    origin:   countryName(r.countryOfOrigin, lang),
  })),
];

const explorerColumns = [
  { key: 'company',  label: 'Entreprise' },
  { key: 'variety',  label: 'Variété',   mono: true },
  { key: 'sector',   label: 'Secteur',   mono: true },
  { key: 'category', label: 'Catégorie', mono: true },
  { key: 'origin',   label: 'Origine',   mono: true },
];

const tr = getTranslations(lang);
const explorerI18n = {
  search_placeholder: tr.explorer.search_placeholder,
  filter_country:     tr.explorer.filter_country,
  filter_category:    tr.explorer.filter_category,
  filter_all:         tr.explorer.filter_all,
  no_results:         tr.explorer.no_results,
  showing:            tr.explorer.showing,
  of:                 tr.explorer.of,
  records:            tr.explorer.records,
  prev:               tr.explorer.prev,
  next:               tr.explorer.next,
};
---

<BaseLayout title={t(lang, 'chapters.ch1_title')} lang={lang}>
  <SiteHeader lang={lang} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-14 flex-1">

    <InsightCallout
      stat={insights.dependency.total_records.toLocaleString()}
      label="autorisations d'importation semences et végétaux"
      context="Chine, Amérique, Inde : l'Algérie importe l'essentiel de ses semences de l'étranger."
      accent={true}
    />

    {/* Banana dominance insight */}
    <div class="mb-8 max-w-2xl p-5 rounded-lg border border-line bg-surface flex gap-4 items-start">
      <span class="text-2xl flex-shrink-0">🌿</span>
      <div>
        <p class="text-xs font-mono font-bold text-forest mb-1">Le pari le plus risqué : la banane</p>
        <p class="text-sm text-muted font-body leading-relaxed">
          La banane représente <strong class="text-ink">{insights.dependency.banana_share_pct}%</strong> des autorisations de la catégorie Fruits, soit <strong class="text-ink">{insights.dependency.banana_count}</strong> licences pour un seul fruit importé du Costa Rica, de Colombie et du Guatemala. La dépendance semencière inclut aussi les produits de consommation finis.
        </p>
      </div>
    </div>

    <SectionHeader
      chapterNum={t(lang, 'chapters.ch1_num')}
      title={t(lang, 'chapters.ch1_title')}
      lead={t(lang, 'chapters.ch1_lead')}
      client:visible
    />

    <div class="mb-10 p-5 bg-surface border border-line rounded-lg max-w-2xl">
      <p class="text-sm text-muted font-body leading-relaxed">
        <span class="font-mono text-forest font-bold text-2xl">{totalCount.toLocaleString('fr-FR')}</span>
        {' '}{t(lang, 'stats.fruit_imports')}
      </p>
    </div>

    <section class="mb-14">
      <HorizontalBarChart
        data={countryData}
        maxBars={15}
        title={t(lang, 'explorer.filter_country')}
        isRtl={false}
        client:visible
      />
    </section>

    <section class="mb-10">
      <WorldMap
        data={worldMapChartData}
        title="Carte des sources d'importation: semences et plantes"
        client:visible
      />
    </section>

    <div class="grid md:grid-cols-2 gap-8 mb-14">
      <HorizontalBarChart
        data={plantCatData}
        colorByLabel={true}
        title="Catégories de produits végétaux"
        isRtl={false}
        client:visible
      />
      <HorizontalBarChart
        data={seedMatData}
        colorByLabel={false}
        title="Types de matières semencières"
        isRtl={false}
        client:visible
      />
    </div>

    <h2 class="font-display font-bold text-display-sm text-ink mb-6">
      {t(lang, 'chapters.explore')}
    </h2>

    <DataExplorer
      rows={combinedExplorerRows}
      columns={explorerColumns}
      searchKeys={['company', 'variety', 'origin']}
      filterKey="sector"
      i18n={explorerI18n}
      client:visible
    />

    {/* Download section */}
    <div class="mt-10 mb-4 p-5 rounded-lg bg-surface border border-line max-w-2xl">
      <p class="text-xs font-mono font-bold text-forest mb-3">Télécharger les données sources (JSON)</p>
      <div class="flex flex-wrap gap-2">
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/plant-products.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Produits végétaux (164 Ko)</a>
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/seeds.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Semences (704 Ko)</a>
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/seedlings.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Plants (120 Ko)</a>
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/potato-seeds.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Pomme de terre (12 Ko)</a>
      </div>
    </div>

    {/* Data quality note */}
    <div class="mb-10 max-w-2xl p-5 rounded-lg" style="background: rgba(252,92,101,0.04); border: 1px solid rgba(252,92,101,0.18);">
      <p class="text-xs font-mono font-bold mb-2" style="color: #e03131;">⚠ Qualité des données brutes</p>
      <p class="text-sm font-body leading-relaxed text-muted">
        Les données originales contiennent <strong class="text-ink">plus de 90 noms différents</strong> pour la même variété : "BANANE", "banane", "BANANES FRAICHES", "Bananes destinées à la consommation humaine", toutes équivalentes. 492 variantes de pays normalisées en 36 codes ISO.
      </p>
    </div>

    {narrative && (
      <div class="mb-10 max-w-2xl p-5 rounded-lg bg-surface border border-line" style="border-left: 3px solid #2d6a4f;">
        <p class="text-xs font-mono font-bold text-forest mb-2">
          {lang === 'ar' ? '✦ تحليل ذكاء اصطناعي' : lang === 'fr' ? '✦ Analyse par IA' : '✦ AI Analysis'}
        </p>
        <p class="text-sm font-body leading-relaxed text-ink">{narrative}</p>
      </div>
    )}

    <ChapterNav
      lang={lang}
      next={{ href: '/fr/chemicals', num: '02', title: t(lang, 'chapters.ch2_title') }}
    />

  </main>

  <SiteFooter lang={lang} />
</BaseLayout>

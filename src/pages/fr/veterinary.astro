---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/shared/SiteHeader.astro';
import SiteFooter from '../../components/shared/SiteFooter.astro';
import { SectionHeader } from '../../components/shared/SectionHeader.tsx';
import { HorizontalBarChart } from '../../components/charts/HorizontalBarChart';
import { WilayaMap } from '../../components/charts/WilayaMap';
import { DataExplorer } from '../../components/explorer/DataExplorer';
import { t, getTranslations } from '../../lib/i18n';
import ChapterNav from '../../components/shared/ChapterNav.astro';
import InsightCallout from '../../components/shared/InsightCallout.astro';
import { loadVetAuthorizations, loadVetDistributors, loadVetMedicineImporters } from '../../lib/data';
import { WILAYA_BY_CODE, wilayaCodeFromName } from '../../data/wilaya-names';
import type { Lang } from '../../lib/types';
import insightsJson from '../../../data/insights.json';
const insights = insightsJson as any;

const lang: Lang = 'fr';

const narrative = (insights.veterinary?.narrative as {fr: string; ar: string; en: string} | undefined)?.[lang];

const auths        = loadVetAuthorizations();
const distributors = loadVetDistributors();
const importers    = loadVetMedicineImporters();

function normalizeWilaya(raw: string): string {
  return raw.trim()
    .replace(/'/g, "'")
    .replace(/\s+/g, ' ')
    .replace(/\b([A-Z]{2,})\b/g, (m) => m.charAt(0) + m.slice(1).toLowerCase())
    .replace('Bba', 'Bordj Bou Arréridj')
    .replace("M'sila", "M'Sila")
    .replace('Boumerdes', 'Boumerdès')
    .replace('Ain Defla', 'Aïn Defla')
    .replace('Ain Temouchent', 'Aïn Témouchent');
}

const wilayaCounts: Record<string, number> = {};
for (const r of distributors) {
  if (r.wilaya) {
    const w = normalizeWilaya(r.wilaya);
    wilayaCounts[w] = (wilayaCounts[w] ?? 0) + 1;
  }
}
const wilayaChartData = Object.entries(wilayaCounts)
  .map(([frName, count]) => {
    const code = wilayaCodeFromName(frName);
    const label = code ? (WILAYA_BY_CODE[code]?.[lang] ?? frName) : frName;
    return { label, count };
  })
  .sort((a, b) => b.count - a.count)
  .slice(0, 20);

// Wilayas with zero vet distributors
const coveredWilayas = new Set(Object.keys(wilayaCounts).map(w => w.toLowerCase()));
const absentWilayas = Object.values(WILAYA_BY_CODE)
  .filter(w => !Array.from(coveredWilayas).some(c => c.includes(w.fr.toLowerCase()) || c.includes(w.en.toLowerCase())))
  .map(w => w.fr)
  .sort();

const typeCounts: Record<string, number> = {};
const typeLabelMap: Record<string, string> = {};
for (const r of auths) {
  const code = r.productType || 'Autre';
  typeCounts[code] = (typeCounts[code] ?? 0) + 1;
  if (!typeLabelMap[code]) {
    typeLabelMap[code] = r.productTypeLabel?.[lang] ?? code;
  }
}
const typeChartData = Object.entries(typeCounts)
  .map(([code, count]) => ({ label: typeLabelMap[code] ?? code, count }))
  .sort((a, b) => b.count - a.count);

const explorerRows = distributors.map(r => ({
  company: r.companyNameAr || r.company,
  wilaya:  (() => {
    if (!r.wilaya) return r.wilaya;
    const w = normalizeWilaya(r.wilaya);
    const code = wilayaCodeFromName(w);
    return code ? (WILAYA_BY_CODE[code]?.[lang] ?? r.wilaya) : r.wilaya;
  })(),
  number:  r.number,
  address: r.address,
}));

const authExplorerRows = auths.map(r => ({
  company:  r.companyNameAr || r.company,
  auth_num: r.authorizationNumber,
  type:     r.productTypeLabel?.[lang] ?? r.productType,
}));

const authExplorerColumns = [
  { key: 'company',  label: 'Entreprise' },
  { key: 'auth_num', label: "N° d'autorisation", mono: true },
  { key: 'type',     label: 'Type de produit',   mono: true },
];

const explorerColumns = [
  { key: 'company', label: 'Entreprise' },
  { key: 'wilaya',  label: 'Wilaya',   mono: true },
  { key: 'number',  label: 'Numéro',   mono: true },
  { key: 'address', label: 'Adresse' },
];

const tr = getTranslations(lang);
const explorerI18n = {
  search_placeholder: tr.explorer.search_placeholder,
  filter_country:     tr.explorer.filter_country,
  filter_category:    tr.explorer.filter_category,
  filter_all:         tr.explorer.filter_all,
  no_results:         tr.explorer.no_results,
  showing:            tr.explorer.showing,
  of:                 tr.explorer.of,
  records:            tr.explorer.records,
  prev:               tr.explorer.prev,
  next:               tr.explorer.next,
};
---

<BaseLayout title={t(lang, 'chapters.ch4_title')} lang={lang}>
  <SiteHeader lang={lang} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-14 flex-1">

    <InsightCallout
      stat={insights.veterinary.wilayas_absent.toLocaleString()}
      label="wilayas sans distributeur vétérinaire"
      context={`Sur 58 wilayas, ${insights.veterinary.wilayas_absent} n'ont aucun distributeur agréé. L'ouest et le Grand Sud sont les plus touchés.`}
      accent={true}
    />

    <SectionHeader
      chapterNum={t(lang, 'chapters.ch4_num')}
      title={t(lang, 'chapters.ch4_title')}
      lead={t(lang, 'chapters.ch4_lead')}
      client:visible
    />

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{auths.length.toLocaleString('fr-FR')}</div>
        <div class="text-xs text-muted font-body mt-1">autorisations</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{distributors.length.toLocaleString('fr-FR')}</div>
        <div class="text-xs text-muted font-body mt-1">distributeurs</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{importers.length.toLocaleString('fr-FR')}</div>
        <div class="text-xs text-muted font-body mt-1">importateurs</div>
      </div>
    </div>

    <section class="mb-10">
      <WilayaMap
        counts={wilayaCounts}
        title="Répartition des distributeurs vétérinaires par wilaya (58 wilayas algériennes)"
        lang="fr"
        client:visible
      />
    </section>

    <div class="grid md:grid-cols-2 gap-8 mb-14">
      <HorizontalBarChart
        data={wilayaChartData}
        maxBars={20}
        colorByLabel={true}
        title="Distributeurs par wilaya"
        isRtl={false}
        client:visible
      />
      <HorizontalBarChart
        data={typeChartData}
        colorByLabel={false}
        title="Types de produits autorisés"
        isRtl={false}
        client:visible
      />
    </div>

    {/* Absent wilayas */}
    <div class="mb-10 max-w-2xl p-5 rounded-lg" style="background: rgba(252,92,101,0.04); border: 1px solid rgba(252,92,101,0.18);">
      <p class="text-xs font-mono font-bold mb-2" style="color: #e03131;">Wilayas sans distributeur ({absentWilayas.length} wilayas)</p>
      <p class="text-sm font-body leading-relaxed text-muted mb-3">
        Ces wilayas ne disposent d'aucun distributeur vétérinaire agréé. La plupart se trouvent dans le sud, pourtant zone principale d'élevage de chameaux et de moutons.
      </p>
      <div class="flex flex-wrap gap-2">
        {absentWilayas.map((w: string) => (
          <span class="text-xs font-mono px-2 py-0.5 rounded" style="background: rgba(252,92,101,0.1); color: #c92a2a;">{w}</span>
        ))}
      </div>
    </div>

    <h2 class="font-display font-bold text-display-sm text-ink mb-6">
      {t(lang, 'chapters.explore')}
    </h2>
    <DataExplorer
      rows={explorerRows}
      columns={explorerColumns}
      searchKeys={['company', 'wilaya', 'address']}
      filterKey="wilaya"
      i18n={explorerI18n}
      client:visible
    />

    {/* Download section */}
    <div class="mt-10 mb-4 p-5 rounded-lg bg-surface border border-line max-w-2xl">
      <p class="text-xs font-mono font-bold text-forest mb-3">Télécharger les données sources (JSON)</p>
      <div class="flex flex-wrap gap-2">
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/vet-distributors.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Distributeurs vétérinaires (48 Ko)</a>
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/vet-authorizations.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Autorisations médicaments (64 Ko)</a>
        <a href="https://raw.githubusercontent.com/ta9in-oss/madr_transparency/main/data/vet-medicine-importers.json" download class="text-xs font-mono px-3 py-1.5 rounded border border-line bg-white text-forest hover:bg-surface transition-colors">Importateurs (16 Ko)</a>
      </div>
    </div>

    {narrative && (
      <div class="mb-10 max-w-2xl p-5 rounded-lg bg-surface border border-line" style="border-left: 3px solid #2d6a4f;">
        <p class="text-xs font-mono font-bold text-forest mb-2">
          {lang === 'ar' ? '✦ تحليل ذكاء اصطناعي' : lang === 'fr' ? '✦ Analyse par IA' : '✦ AI Analysis'}
        </p>
        <p class="text-sm font-body leading-relaxed text-ink">{narrative}</p>
      </div>
    )}

    <ChapterNav
      lang={lang}
      prev={{ href: '/fr/players', num: '03', title: t(lang, 'chapters.ch3_title') }}
    />

  </main>

  <SiteFooter lang={lang} />
</BaseLayout>

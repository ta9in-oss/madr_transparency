---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/shared/SiteHeader.astro';
import SiteFooter from '../../components/shared/SiteFooter.astro';
import { t } from '../../lib/i18n';
import type { Lang } from '../../lib/types';
import insightsJson from '../../../data/insights.json';
const insights = insightsJson as any;

const lang: Lang = 'fr';

const totalRecords = insights.players.total_permits;

const chapters = [
  {
    num:   t(lang, 'chapters.ch1_num'),
    title: t(lang, 'chapters.ch1_title'),
    lead:  t(lang, 'chapters.ch1_lead'),
    href:  '/fr/dependency',
    count: insights.dependency.total_records,
    hook:  "La Chine d'abord. L'Amérique ensuite. L'Algérie ne cultive pas ses semences.",
  },
  {
    num:   t(lang, 'chapters.ch2_num'),
    title: t(lang, 'chapters.ch2_title'),
    lead:  t(lang, 'chapters.ch2_lead'),
    href:  '/fr/chemicals',
    count: insights.chemicals.total,
    hook:  `${insights.chemicals.spain_count.toLocaleString()} produits d'Espagne seulement. Que pulvérise-t-on sur vos tomates ?`,
  },
  {
    num:   t(lang, 'chapters.ch3_num'),
    title: t(lang, 'chapters.ch3_title'),
    lead:  t(lang, 'chapters.ch3_lead'),
    href:  '/fr/players',
    count: insights.players.total_permits,
    hook:  `Une seule entreprise = ${insights.players.top_companies[0].count} licences. Qui contrôle notre chaîne alimentaire ?`,
  },
  {
    num:   t(lang, 'chapters.ch4_num'),
    title: t(lang, 'chapters.ch4_title'),
    lead:  t(lang, 'chapters.ch4_lead'),
    href:  '/fr/veterinary',
    count: insights.veterinary.auth_count + insights.veterinary.distributor_count + insights.veterinary.importer_count,
    hook:  `${insights.veterinary.wilayas_absent} wilayas sans médicament vétérinaire. Le bétail en marge.`,
  },
];
---

<BaseLayout title={t(lang, 'home.title')} lang={lang}>
  <SiteHeader lang={lang} />

  <main class="flex-1">

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-12">
      <div class="max-w-3xl">
        <p class="font-mono text-sm text-forest tracking-widest uppercase mb-4">Enquête de données · Ministère algérien de l'Agriculture</p>
        <h1 class="font-display font-bold text-display-lg text-ink leading-tight mb-6">
          {t(lang, 'home.title')}
        </h1>
        <p class="text-lg text-muted leading-relaxed mb-8 font-body max-w-2xl">
          {t(lang, 'home.subtitle')}
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/fr/chemicals"
            class="inline-flex items-center px-5 py-2.5 bg-forest text-paper font-body text-sm rounded hover:bg-forest-dark transition-colors"
          >
            {t(lang, 'home.cta_explore')} →
          </a>
          <a
            href="/fr/dependency"
            class="inline-flex items-center px-5 py-2.5 border border-line text-ink font-body text-sm rounded hover:bg-surface transition-colors"
          >
            {t(lang, 'home.cta_story')}
          </a>
        </div>
      </div>
    </section>

    <!-- Shock stats bar -->
    <section class="border-y border-line bg-surface">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 grid grid-cols-2 sm:grid-cols-4 gap-0 divide-x divide-line">
        <div class="px-6 first:ps-0 last:pe-0">
          <div class="font-mono font-bold text-forest text-3xl sm:text-4xl tabular-nums">{totalRecords.toLocaleString('fr-FR')}</div>
          <div class="text-xs text-muted font-body mt-1">{t(lang, 'home.total_records')}</div>
        </div>
        <div class="px-6">
          <div class="font-mono font-bold text-ink text-3xl sm:text-4xl tabular-nums">{insights.chemicals.total.toLocaleString('fr-FR')}</div>
          <div class="text-xs text-muted font-body mt-1">{t(lang, 'stats.agrochemicals')}</div>
        </div>
        <div class="px-6">
          <div class="font-mono font-bold text-ink text-3xl sm:text-4xl tabular-nums">39</div>
          <div class="text-xs text-muted font-body mt-1">wilayas sur 58 avec distribution vétérinaire</div>
        </div>
        <div class="px-6">
          <div class="font-mono font-bold text-ink text-3xl sm:text-4xl tabular-nums">448</div>
          <div class="text-xs text-muted font-body mt-1">licences pour une seule entreprise (PROFERT)</div>
        </div>
      </div>
    </section>

    <!-- Chapter cards -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
      <div class="grid sm:grid-cols-2 gap-5">
        {chapters.map(({ num, title, lead, href, count, hook }) => (
          <a
            href={href}
            class="group flex flex-col gap-4 p-6 bg-surface border border-line rounded-lg hover:border-forest hover:bg-white transition-all"
          >
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-xs text-forest tracking-widest uppercase">{num}</span>
              <span class="font-mono text-xs text-muted tabular-nums">{count.toLocaleString('fr-FR')} enreg.</span>
            </div>
            <div>
              <h2 class="font-display font-bold text-xl text-ink group-hover:text-forest transition-colors mb-2">
                {title}
              </h2>
              <p class="text-sm text-forest font-mono font-medium mb-3">{hook}</p>
              <p class="text-sm text-muted leading-relaxed font-body">{lead}</p>
            </div>
            <span class="text-sm text-forest font-body mt-auto flex items-center gap-1">
              {t(lang, 'chapters.explore')} <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Methodology note -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-14">
      <div class="border border-line rounded-lg p-6 bg-surface max-w-2xl">
        <p class="font-mono text-xs text-forest tracking-widest uppercase mb-3">Méthodologie</p>
        <p class="text-sm text-muted font-body leading-relaxed mb-3">
          <strong class="text-ink">Note importante :</strong> ce site présente uniquement les autorisations d'importation publiées par le ministère de l'Agriculture.
          Il ne représente pas la production agricole algérienne totale. L'Algérie produit localement dans de nombreux domaines.
          Ce que vous voyez ici, c'est le côté resté invisible : ce qui entre de l'étranger.
        </p>
        <p class="text-sm text-muted font-body leading-relaxed">
          Les données sont extraites de la page Transparence du site du ministère de l'Agriculture et du Développement rural algérien.
          Elles ont été traitées et structurées par programme. Dernière mise à jour juillet 2025.
          <a href="https://github.com/ta9in-oss/madr_transparency" target="_blank" rel="noopener noreferrer" class="text-forest hover:text-forest-dark ms-1">→ Code source ouvert</a>
        </p>
      </div>
    </section>

  </main>

  <SiteFooter lang={lang} />
</BaseLayout>

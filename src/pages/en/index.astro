---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Lang } from '../../lib/types';
const lang: Lang = 'en';
---
<BaseLayout title="MADR Transparency — English version" lang={lang}>
  <main class="max-w-2xl mx-auto px-6 py-24 text-center flex-1">
    <p class="font-mono text-sm text-muted mb-4 tracking-widest uppercase">02</p>
    <h1 class="font-display font-bold text-3xl text-ink mb-6">English version coming soon</h1>
    <p class="text-muted font-body mb-10">This site is currently available in Arabic only. An English translation is underway.</p>
    <a href="/" class="inline-flex items-center px-5 py-2.5 bg-forest text-paper font-body text-sm rounded hover:bg-forest-dark transition-colors">
      → الموقع بالعربية
    </a>
  </main>
</BaseLayout>

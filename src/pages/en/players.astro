---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/shared/SiteHeader.astro';
import SiteFooter from '../../components/shared/SiteFooter.astro';
import { SectionHeader } from '../../components/shared/SectionHeader';
import { HorizontalBarChart } from '../../components/charts/HorizontalBarChart';
import { DataExplorer } from '../../components/explorer/DataExplorer';
import { t, getTranslations } from '../../lib/i18n';
import ChapterNav from '../../components/shared/ChapterNav.astro';
import InsightCallout from '../../components/shared/InsightCallout.astro';
import { loadCompanyStats } from '../../lib/data';
import { SECTOR_LABELS } from '../../lib/normalize';
import type { Lang } from '../../lib/types';
import insightsJson from '../../../data/insights.json';
const insights = insightsJson as any;

const lang: Lang = 'en';

const narrative = (insights.players?.narrative as {fr: string; ar: string; en: string} | undefined)?.[lang];

const companies = loadCompanyStats();
const uniqueCompanies = companies.length;
const totalLicenses = companies.reduce((s, c) => s + c.totalLicenses, 0);

const companyChartData = companies
  .slice(0, 20)
  .map((c) => ({ label: c.name, count: c.totalLicenses }));

const top1pct = companies.slice(0, Math.ceil(companies.length * 0.01));
const top1pctLicenses = top1pct.reduce((s, c) => s + c.totalLicenses, 0);
const top1pctPct = Math.round((top1pctLicenses / totalLicenses) * 100);

const top10 = companies.slice(0, 10);
const top10Licenses = top10.reduce((s, c) => s + c.totalLicenses, 0);
const top10Pct = Math.round((top10Licenses / totalLicenses) * 100);

const explorerRows = companies.map((c) => ({
  company:    c.name,
  company_ar: c.nameAr || '—',
  sectors:    c.sectors.map(s => SECTOR_LABELS[s]?.[lang] ?? s).join(' · '),
  licenses:   String(c.totalLicenses),
}));

const explorerColumns = [
  { key: 'company',    label: 'Company (French)', mono: true },
  { key: 'company_ar', label: 'Arabic name' },
  { key: 'sectors',    label: 'Sectors',          mono: true },
  { key: 'licenses',   label: 'Licenses',         mono: true },
];

const tr = getTranslations(lang);
const explorerI18n = {
  search_placeholder: tr.explorer.search_placeholder,
  filter_country:     tr.explorer.filter_country,
  filter_category:    tr.explorer.filter_category,
  filter_all:         tr.explorer.filter_all,
  no_results:         tr.explorer.no_results,
  showing:            tr.explorer.showing,
  of:                 tr.explorer.of,
  records:            tr.explorer.records,
  prev:               tr.explorer.prev,
  next:               tr.explorer.next,
};
---

<BaseLayout title={t(lang, 'chapters.ch3_title')} lang={lang}>
  <SiteHeader lang={lang} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-14 flex-1">

    <InsightCallout
      stat={insights.players.top_companies[0].count.toLocaleString()}
      label="licenses held by one company"
      context={`PROFERT SPA holds ${insights.players.top_companies[0].count} licenses — ${(insights.players.top_companies[0].count / insights.players.total_permits * 100).toFixed(1)}% of all ${insights.players.total_permits.toLocaleString()} permits. The top 10 companies control ${insights.players.top_10_share_pct}% of the market.`}
      accent={true}
    />

    <SectionHeader
      chapterNum={t(lang, 'chapters.ch3_num')}
      title={t(lang, 'chapters.ch3_title')}
      lead={t(lang, 'chapters.ch3_lead')}
      client:visible
    />

    <div class="grid sm:grid-cols-4 gap-4 mb-10">
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{uniqueCompanies.toLocaleString('en-US')}</div>
        <div class="text-xs text-muted font-body mt-1">unique companies</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{totalLicenses.toLocaleString('en-US')}</div>
        <div class="text-xs text-muted font-body mt-1">import licenses</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{top1pctPct}%</div>
        <div class="text-xs text-muted font-body mt-1">of licenses for only {top1pct.length} company (1%)</div>
      </div>
      <div class="p-4 bg-surface border border-line rounded-lg text-center">
        <div class="font-mono text-forest font-bold text-2xl">{insights.players.hhi_index.toFixed(4)}</div>
        <div class="text-xs text-muted font-body mt-1">HHI index (market concentration)</div>
      </div>
    </div>

    {/* Market concentration insight */}
    <div class="mb-10 max-w-2xl p-5 rounded-lg" style="background: rgba(34,166,179,0.06); border: 1px solid rgba(34,166,179,0.2);">
      <div class="flex gap-6 flex-wrap items-center">
        <div>
          <div class="font-mono font-bold leading-none mb-1" style="font-size: 3rem; color: #22a6b3;">{top10Pct}%</div>
          <div class="text-xs text-muted font-body">of licences in 10 companies</div>
        </div>
        <p class="text-sm text-muted font-body leading-relaxed flex-1 min-w-[200px]">
          Of {uniqueCompanies} companies, the top 10 hold {top10Licenses.toLocaleString('en-GB')} licences out of {totalLicenses.toLocaleString('en-GB')}. PROFERT alone accounts for {Math.round((companies[0]?.totalLicenses ?? 0) / totalLicenses * 100 * 10) / 10}% of all licences.
        </p>
      </div>
    </div>

    <section class="mb-14">
      <HorizontalBarChart
        data={companyChartData}
        maxBars={20}

        title="Top 20 companies by number of licenses"
        isRtl={false}
        client:visible
      />
    </section>

    <h2 class="font-display font-bold text-display-sm text-ink mb-6">
      {t(lang, 'chapters.explore')}
    </h2>

    <DataExplorer
      rows={explorerRows}
      columns={explorerColumns}
      searchKeys={['company', 'company_ar', 'sectors']}
      filterKey="sectors"
      i18n={explorerI18n}
      client:visible
    />

    {narrative && (
      <div class="mb-10 max-w-2xl p-5 rounded-lg bg-surface border border-line" style="border-left: 3px solid #2d6a4f;">
        <p class="text-xs font-mono font-bold text-forest mb-2">
          {lang === 'ar' ? '✦ تحليل ذكاء اصطناعي' : lang === 'fr' ? '✦ Analyse par IA' : '✦ AI Analysis'}
        </p>
        <p class="text-sm font-body leading-relaxed text-ink">{narrative}</p>
      </div>
    )}

    <ChapterNav
      lang={lang}
      prev={{ href: '/en/chemicals', num: '02', title: t(lang, 'chapters.ch2_title') }}
      next={{ href: '/en/veterinary', num: '04', title: t(lang, 'chapters.ch4_title') }}
    />

  </main>

  <SiteFooter lang={lang} />
</BaseLayout>
